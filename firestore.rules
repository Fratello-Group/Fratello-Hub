rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isBootstrapOwner() {
      return signedIn()
        && (
          signedInEmail() == 'prefontainech@gmail.com'
          || signedInEmail() == 'russ@fratellocoffee.com'
        );
    }

    function profilePath(uid) {
      return /databases/$(database)/documents/hubProfiles/$(uid);
    }

    function invitePath(email) {
      return /databases/$(database)/documents/hubInvites/$(email);
    }

    function isOwner() {
      return isBootstrapOwner()
        || (
          signedIn()
          && exists(profilePath(request.auth.uid))
          && get(profilePath(request.auth.uid)).data.profile == 'owner'
          && get(profilePath(request.auth.uid)).data.status == 'active'
        );
    }

    function isController() {
      return signedIn()
        && exists(profilePath(request.auth.uid))
        && get(profilePath(request.auth.uid)).data.profile == 'controller'
        && get(profilePath(request.auth.uid)).data.status == 'active';
    }

    function isOwnerOrController() {
      return isOwner() || isController();
    }

    function hasActiveProfile(profile) {
      return signedIn()
        && exists(profilePath(request.auth.uid))
        && get(profilePath(request.auth.uid)).data.profile == profile
        && get(profilePath(request.auth.uid)).data.status == 'active';
    }

    function canUseAvatarBuilder() {
      return isOwnerOrController()
        || hasActiveProfile('marketing')
        || hasActiveProfile('sales');
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isSelfUserId(userId) {
      return signedIn()
        && exists(userPath(userId))
        && get(userPath(userId)).data.email == signedInEmail()
        && get(userPath(userId)).data.active == true;
    }

    function isSelfUserRecord(data) {
      return signedIn()
        && data.email == signedInEmail()
        && data.active == true;
    }

    function isVacation(data) {
      return data.type == 'vacation';
    }

    function isSickDay(data) {
      return data.type == 'sick';
    }

    function isKnownTimeOffType(data) {
      return data.type in ['vacation', 'sick'];
    }

    function isRequester(data) {
      return data.user_id != null && isSelfUserId(data.user_id);
    }

    function isVacationApprover(data) {
      return isVacation(data)
        && data.approver_id != null
        && isSelfUserId(data.approver_id);
    }

    function canReadTimeOffRequest(data) {
      return isOwnerOrController()
        || isRequester(data)
        || (isVacation(data) && isVacationApprover(data));
    }

    function validUserTimeOffCreate(data) {
      return isKnownTimeOffType(data)
        && isRequester(data)
        && data.created_via == 'hub'
        && (
          (
            isVacation(data)
            && data.status in ['pending', 'approved']
            && (data.status == 'pending' || isOwner())
          )
          || (
            isSickDay(data)
            && data.status == 'approved'
            && data.approver_id == null
          )
        );
    }

    function validUserTimeOffUpdate(before, after) {
      return isRequester(before)
        && before.user_id == after.user_id
        && before.type == after.type
        && before.created_via == after.created_via
        && (
          (
            isVacation(before)
            && before.status == 'pending'
            && after.status in ['pending', 'cancelled']
          )
          || (
            isSickDay(before)
            && before.edit_locked_at != null
            && request.time <= before.edit_locked_at
            && after.status in ['approved', 'cancelled']
          )
        );
    }

    function selfProfileFieldsDoNotEscalate(uid) {
      return request.auth.uid == uid
        && resource.data.status == 'active'
        && resource.data.email == signedInEmail()
        && request.resource.data.email == resource.data.email
        && request.resource.data.profile == resource.data.profile
        && request.resource.data.status == resource.data.status
        && request.resource.data.role_tier == resource.data.role_tier
        && request.resource.data.manager_id == resource.data.manager_id
        && request.resource.data.department == resource.data.department;
    }

    function validAvatarStatus(data) {
      return data.status in ['Untested', 'Live', 'Worked', 'Flopped'];
    }

    function isAvatarCreator(data) {
      return signedIn()
        && data.created_by_uid == request.auth.uid
        && data.created_by_email == signedInEmail();
    }

    match /hubProfiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isOwner());

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == signedInEmail()
        && (
          (
            isBootstrapOwner()
            && request.resource.data.profile == 'owner'
            && request.resource.data.status == 'active'
          )
          || (
            exists(invitePath(signedInEmail()))
            && get(invitePath(signedInEmail())).data.status != 'disabled'
            && request.resource.data.profile == get(invitePath(signedInEmail())).data.profile
            && request.resource.data.status == 'active'
          )
        );

      allow update: if isOwner() || selfProfileFieldsDoNotEscalate(uid);
      allow delete: if isOwner();
    }

    match /hubInvites/{email} {
      allow read: if isOwner() || (signedIn() && email == signedInEmail());
      allow create, update: if isOwner();
      allow delete: if isOwner();
    }

    match /users/{userId} {
      allow get: if isOwnerOrController() || isSelfUserRecord(resource.data);
      allow list: if isOwnerOrController();
      allow create, update: if isOwnerOrController();
      allow delete: if isOwner();
    }

    match /time_off_requests/{requestId} {
      allow get, list: if canReadTimeOffRequest(resource.data);
      allow create: if isOwnerOrController() || validUserTimeOffCreate(request.resource.data);
      allow update: if isOwnerOrController() || validUserTimeOffUpdate(resource.data, request.resource.data);
      allow delete: if false;
    }

    match /approvals/{approvalId} {
      allow read: if isOwnerOrController()
        || (
          resource.data.approver_id != null
          && isSelfUserId(resource.data.approver_id)
        );
      allow write: if false;
    }

    match /activity_log/{activityId} {
      allow read: if isOwner();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isOwner();
      allow write: if false;
    }

    match /holidays/{holidayId} {
      allow read: if signedIn();
      allow create, update: if isOwner();
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow create, update: if isOwner();
      allow delete: if false;
    }

    match /expense_reports/{expenseId} {
      allow get, list: if signedIn() && resource.data.user_email == signedInEmail();
      allow create: if signedIn() && request.resource.data.user_email == signedInEmail();
      allow delete: if signedIn() && resource.data.user_email == signedInEmail();
      allow update: if false;
    }

    match /avatar_logs/{avatarId} {
      allow read: if canUseAvatarBuilder();
      allow create: if canUseAvatarBuilder()
        && isAvatarCreator(request.resource.data)
        && validAvatarStatus(request.resource.data)
        && request.resource.data.created_via == 'hub-avatar-builder';
      allow update: if canUseAvatarBuilder()
        && (isOwnerOrController() || isAvatarCreator(resource.data))
        && request.resource.data.created_by_uid == resource.data.created_by_uid
        && request.resource.data.created_by_email == resource.data.created_by_email
        && request.resource.data.created_via == resource.data.created_via
        && validAvatarStatus(request.resource.data);
      allow delete: if canUseAvatarBuilder()
        && (isOwnerOrController() || isAvatarCreator(resource.data));
    }
  }
}
