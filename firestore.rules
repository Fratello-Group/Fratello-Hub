rules_version = '2';

// Firestore security rules for the Fratello Hub.
// Deployed automatically by .github/workflows/deploy-firestore-rules.yml
// whenever this file changes on main (no manual console paste needed).

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isBootstrapOwner() {
      return signedIn()
        && (
          signedInEmail() == 'prefontainech@gmail.com'
          || signedInEmail() == 'russ@fratellocoffee.com'
        );
    }

    function profilePath(uid) {
      return /databases/$(database)/documents/hubProfiles/$(uid);
    }

    function invitePath(email) {
      return /databases/$(database)/documents/hubInvites/$(email);
    }

    function isOwner() {
      return isBootstrapOwner()
        || (
          signedIn()
          && exists(profilePath(request.auth.uid))
          && get(profilePath(request.auth.uid)).data.profile == 'owner'
          && get(profilePath(request.auth.uid)).data.status == 'active'
        );
    }

    function isController() {
      return signedIn()
        && exists(profilePath(request.auth.uid))
        && get(profilePath(request.auth.uid)).data.profile == 'controller'
        && get(profilePath(request.auth.uid)).data.status == 'active';
    }

    function isOwnerOrController() {
      return isOwner() || isController();
    }

    function hasActiveProfile(profile) {
      return signedIn()
        && exists(profilePath(request.auth.uid))
        && get(profilePath(request.auth.uid)).data.profile == profile
        && get(profilePath(request.auth.uid)).data.status == 'active';
    }

    function canUseAvatarBuilder() {
      return isOwnerOrController()
        || hasActiveProfile('marketing')
        || hasActiveProfile('sales');
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isSelfUserId(userId) {
      return signedIn()
        && exists(userPath(userId))
        && get(userPath(userId)).data.email == signedInEmail()
        && get(userPath(userId)).data.active == true;
    }

    function isSelfUserRecord(data) {
      return signedIn()
        && data.email == signedInEmail()
        && data.active == true;
    }

    function isVacation(data) {
      return data.type == 'vacation';
    }

    function isSickDay(data) {
      return data.type == 'sick';
    }

    function isKnownTimeOffType(data) {
      return data.type in ['vacation', 'sick'];
    }

    function isRequester(data) {
      return data.user_id != null && isSelfUserId(data.user_id);
    }

    function isVacationApprover(data) {
      return isVacation(data)
        && data.approver_id != null
        && isSelfUserId(data.approver_id);
    }

    // Roasting / Packaging / Warehouse roll up to one "Production" team.
    // Must stay in sync with teamGroupOf() in system/api/firestore-client.js.
    function teamGroup(dept) {
      return (dept == 'Roasting' || dept == 'Packaging' || dept == 'Warehouse' || dept == 'Production')
        ? 'Production' : dept;
    }

    function readerTeam() {
      return teamGroup(get(userPath(signedInEmail())).data.department);
    }

    // A teammate may read a VACATION request from their own team, so a team can
    // avoid two people being away at once. vacation_team is set + validated on
    // create and is empty for sick days, which stay private.
    function sameTeamVacation(data) {
      return data.get('vacation_team', '') != ''
        && exists(userPath(signedInEmail()))
        && data.vacation_team == readerTeam();
    }

    function canReadTimeOffRequest(data) {
      return isOwnerOrController()
        || isRequester(data)
        || (isVacation(data) && isVacationApprover(data))
        || sameTeamVacation(data);
    }

    function validUserTimeOffCreate(data) {
      return isKnownTimeOffType(data)
        && isRequester(data)
        && data.created_via == 'hub'
        // vacation_team may not be forged: empty, or exactly the requester's own team.
        && (
          data.get('vacation_team', '') == ''
          || (exists(userPath(signedInEmail())) && data.vacation_team == readerTeam())
        )
        && (
          (
            isVacation(data)
            && data.status in ['pending', 'approved']
            && (data.status == 'pending' || isOwner())
          )
          || (
            isSickDay(data)
            && data.status == 'approved'
            && data.approver_id == null
          )
        );
    }

    function validUserTimeOffUpdate(before, after) {
      return isRequester(before)
        && before.user_id == after.user_id
        && before.type == after.type
        && before.created_via == after.created_via
        && (
          (
            isVacation(before)
            && before.status == 'pending'
            && after.status in ['pending', 'cancelled']
          )
          || (
            isSickDay(before)
            && before.edit_locked_at != null
            && request.time <= before.edit_locked_at
            && after.status in ['approved', 'cancelled']
          )
        );
    }

    function selfProfileFieldsDoNotEscalate(uid) {
      return request.auth.uid == uid
        && resource.data.status == 'active'
        && resource.data.email == signedInEmail()
        && request.resource.data.email == resource.data.email
        && request.resource.data.profile == resource.data.profile
        && request.resource.data.status == resource.data.status
        && request.resource.data.role_tier == resource.data.role_tier
        && request.resource.data.manager_id == resource.data.manager_id
        && request.resource.data.department == resource.data.department
        && request.resource.data.get('safetyOfficer', false) == resource.data.get('safetyOfficer', false)
        && request.resource.data.get('cfia_tier', '') == resource.data.get('cfia_tier', '')
        && request.resource.data.get('cfia_department', '') == resource.data.get('cfia_department', '');
    }

    function validAvatarStatus(data) {
      return data.status in ['Untested', 'Live', 'Worked', 'Flopped'];
    }

    function isAvatarCreator(data) {
      return signedIn()
        && data.created_by_uid == request.auth.uid
        && data.created_by_email == signedInEmail();
    }

    // ── CFIA role model ──
    // Kyle = QA / food-safety officer (safetyOfficer flag on the profile); owners always qualify.
    function cfiaProfile() { return get(profilePath(request.auth.uid)).data; }
    function isSafetyOfficer() {
      return isOwner()
        || (
          signedIn() && exists(profilePath(request.auth.uid))
          && cfiaProfile().status == 'active'
          && cfiaProfile().get('safetyOfficer', false) == true
        );
    }
    // Who may verify / sign off and read all records: owner, controller, QA officer.
    function isCfiaVerifier() { return isOwnerOrController() || isSafetyOfficer(); }

    // Field-level validation for an immutable record (must match cfia-core.js exactly).
    function cfiaRecordValid(d) {
      return d.keys().hasOnly([
          'form_code','form_title','sop_code','form_version','record_id','values',
          'performed_by_name','performed_by_is_self','submitted_by_uid','submitted_by_email',
          'submitted_by_name','submitted_at','department','supersedes','created_via'
        ])
        && d.form_code is string && d.form_code.size() > 0
        && d.record_id is string && d.record_id.size() > 0
        && d.values is map
        && d.performed_by_name is string && d.performed_by_name.size() > 0
        && d.performed_by_is_self is bool
        && d.submitted_by_name is string
        && d.submitted_at is timestamp
        && (d.supersedes == null || d.supersedes is string)
        && d.created_via == 'cfia-hub';
    }

    match /hubProfiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isOwner());

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == signedInEmail()
        && (
          (
            isBootstrapOwner()
            && request.resource.data.profile == 'owner'
            && request.resource.data.status == 'active'
          )
          || (
            exists(invitePath(signedInEmail()))
            && get(invitePath(signedInEmail())).data.status != 'disabled'
            && request.resource.data.profile == get(invitePath(signedInEmail())).data.profile
            && request.resource.data.status == 'active'
          )
        );

      allow update: if isOwner() || selfProfileFieldsDoNotEscalate(uid);
      allow delete: if isOwner();
    }

    match /hubInvites/{email} {
      allow read: if isOwner() || (signedIn() && email == signedInEmail());
      allow create, update: if isOwner();
      allow delete: if isOwner();
    }

    match /users/{userId} {
      allow get: if isOwnerOrController() || isSelfUserRecord(resource.data);
      allow list: if isOwnerOrController();
      allow create, update: if isOwnerOrController();
      allow delete: if isOwner();
    }

    match /time_off_requests/{requestId} {
      allow get, list: if canReadTimeOffRequest(resource.data);
      allow create: if isOwnerOrController() || validUserTimeOffCreate(request.resource.data);
      allow update: if isOwnerOrController() || validUserTimeOffUpdate(resource.data, request.resource.data);
      allow delete: if false;
    }

    match /approvals/{approvalId} {
      allow read: if isOwnerOrController()
        || (
          resource.data.approver_id != null
          && isSelfUserId(resource.data.approver_id)
        );
      allow write: if false;
    }

    match /activity_log/{activityId} {
      allow read: if isOwner();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isOwner();
      allow write: if false;
    }

    match /holidays/{holidayId} {
      allow read: if signedIn();
      allow create, update: if isOwner();
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow create, update: if isOwner();
      allow delete: if false;
    }

    match /expense_reports/{expenseId} {
      allow get, list: if signedIn() && resource.data.user_email == signedInEmail();
      allow create: if signedIn() && request.resource.data.user_email == signedInEmail();
      allow delete: if signedIn() && resource.data.user_email == signedInEmail();
      allow update: if false;
    }

    match /avatar_logs/{avatarId} {
      allow read: if canUseAvatarBuilder();
      allow create: if canUseAvatarBuilder()
        && isAvatarCreator(request.resource.data)
        && validAvatarStatus(request.resource.data)
        && request.resource.data.created_via == 'hub-avatar-builder';
      allow update: if canUseAvatarBuilder()
        && (isOwnerOrController() || isAvatarCreator(resource.data))
        && request.resource.data.created_by_uid == resource.data.created_by_uid
        && request.resource.data.created_by_email == resource.data.created_by_email
        && request.resource.data.created_via == resource.data.created_via
        && validAvatarStatus(request.resource.data);
      allow delete: if canUseAvatarBuilder()
        && (isOwnerOrController() || isAvatarCreator(resource.data));
    }

    // ── CFIA / HACCP food-safety records (immutable, audit-grade) ──
    // A completed form is a permanent record: create-only, NEVER edited,
    // NEVER deleted — not by the author, a manager, or the owner. The
    // submitter must stamp THEMSELVES and the SERVER time, so a client
    // (or a bad actor editing the page) cannot forge who or when.
    // A correction is filed as a new record that links via `supersedes`.
    match /cfia_records/{recordId} {
      // Managers + QA see all; a person sees their own.
      allow get, list: if isCfiaVerifier()
        || (signedIn() && resource.data.submitted_by_email == signedInEmail());
      // Create-only, self + server stamped, field-validated.
      allow create: if signedIn()
        && request.resource.data.submitted_by_uid == request.auth.uid
        && request.resource.data.submitted_by_email == signedInEmail()
        && request.resource.data.submitted_at == request.time
        && request.resource.data.created_via == 'cfia-hub'
        && cfiaRecordValid(request.resource.data);
      allow update: if false;   // immutable — corrections are new superseding records
      allow delete: if false;   // append-only — retained >= 5 years, never deleted
    }

    // ── Manager / QA verification sign-offs (the 3-tier oversight chain) ──
    // A department head or QA confirms a set of records was done properly.
    // Separation of duties: the signer must NOT be a submitter of the records signed.
    match /cfia_signoffs/{id} {
      allow get, list: if isCfiaVerifier()
        || (signedIn() && resource.data.signed_by_email == signedInEmail());
      allow create: if isCfiaVerifier()
        && request.resource.data.signed_by_uid == request.auth.uid
        && request.resource.data.signed_by_email == signedInEmail()
        && request.resource.data.signed_at == request.time
        && request.resource.data.created_via == 'cfia-hub-signoff'
        && !(signedInEmail() in request.resource.data.record_submitter_emails);
      allow update: if false;
      allow delete: if false;
    }

    // ── Equipment registry (first-class machines; per-machine history) ──
    match /cfia_equipment/{id} {
      allow get, list: if signedIn();
      allow create, update: if isCfiaVerifier();
      allow delete: if false;   // retire via active:false, never hard-delete
    }

    // ── Training completions (quiz passes; immutable, self-written) ──
    match /cfia_training_completions/{id} {
      allow get, list: if isCfiaVerifier()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == signedInEmail()
        && request.resource.data.taken_at == request.time
        && request.resource.data.created_via == 'cfia-hub-training';
      allow update: if false;
      allow delete: if false;
    }

    // ── Document acknowledgements ("I read SOP vX"; immutable, self-written) ──
    match /cfia_acknowledgements/{id} {
      allow get, list: if isCfiaVerifier()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == signedInEmail()
        && request.resource.data.read_at == request.time
        && request.resource.data.created_via == 'cfia-hub-ack';
      allow update: if false;
      allow delete: if false;
    }
  }
}
