rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function signedInEmail() {
      return request.auth.token.email;
    }

    function isBootstrapOwner() {
      return signedIn()
        && (
          signedInEmail() == 'prefontainech@gmail.com'
          || signedInEmail() == 'russ@fratellocoffee.com'
        );
    }

    function profilePath(uid) {
      return /databases/$(database)/documents/hubProfiles/$(uid);
    }

    function invitePath(email) {
      return /databases/$(database)/documents/hubInvites/$(email);
    }

    function isOwner() {
      return signedIn()
        && exists(profilePath(request.auth.uid))
        && get(profilePath(request.auth.uid)).data.profile == 'owner'
        && get(profilePath(request.auth.uid)).data.status == 'active';
    }

    function selfProfileFieldsDoNotEscalate(uid) {
      return request.auth.uid == uid
        && resource.data.email == signedInEmail()
        && request.resource.data.email == resource.data.email
        && request.resource.data.profile == resource.data.profile
        && request.resource.data.status == resource.data.status;
    }

    match /hubProfiles/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isOwner());

      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == signedInEmail()
        && (
          (
            isBootstrapOwner()
            && request.resource.data.profile == 'owner'
            && request.resource.data.status == 'active'
          )
          || (
            exists(invitePath(signedInEmail()))
            && get(invitePath(signedInEmail())).data.status != 'disabled'
            && request.resource.data.profile == get(invitePath(signedInEmail())).data.profile
            && request.resource.data.status == 'active'
          )
        );

      allow update: if isOwner() || selfProfileFieldsDoNotEscalate(uid);
      allow delete: if false;
    }

    match /hubInvites/{email} {
      allow read: if isOwner() || (signedIn() && email == signedInEmail());
      allow create, update: if isOwner();
      allow delete: if false;
    }
  }
}
